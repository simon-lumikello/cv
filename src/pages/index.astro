---
import "@/styles/global.css";
import { Link2 } from "@lucide/astro";
import SummaryPoint from "@/components/SummaryPoint.astro";
import DetailsCard from "@/components/DetailsCard.astro";
import Layout from "@/layouts/Layout.astro";
import SkillsCard from "@/components/SkillsCard.astro";
import { MY_SKILLS } from "@/assets/MySkills";
import { MY_DETAILS } from "@/assets/MyDetails";
import { MY_TIMELINE_ENTRIES } from "@/assets/MyTimeline";
import Bio from "@/assets/bio.md";
import Timeline from "@/components/Timeline.astro";
import TimelineItem from "@/components/TimelineItem.astro";
---

<Layout>
    <div class="flex flex-col items-center gap-10 pt-8">
        <!-- Details -->
        <DetailsCard details={MY_DETAILS} />

        <!-- Bio -->
        <article class="prose prose-slate w-3/4">
            <Bio />
        </article>
        <div class="page-break"></div>

        <!-- Stack -->
        <h2 class="text-2xl font-light">Tech stack</h2>
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 print:grid-cols-2 gap-6 w-3/4 2xl:w-1/2"
        >
            {MY_SKILLS.map((skill) => <SkillsCard skillGroup={skill} />)}
        </div>
        <div class="page-break"></div>

        <!-- Timeline -->
        <h2 class="text-2xl font-light">Timeline</h2>
        <Timeline>
            {MY_TIMELINE_ENTRIES.map((entry) => <TimelineItem {...entry} />)}
        </Timeline>

        <!-- Github -->
        <a
            href="https://github.com/simon-lumikello/cv"
            class="text-subtle mb-4 print:hidden"
        >
            <SummaryPoint text="This page on GitHub">
                <Link2 slot="icon" />
            </SummaryPoint>
        </a>
    </div>
</Layout>
