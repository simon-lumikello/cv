---
import type { Skill } from "../../types/Skill";
import SkillsList from "./SkillsList.astro";

interface Props {
    items: Skill[];
}

const { items } = Astro.props;
---

<div
    class="card bg-base-200 shadow-md hover:shadow-lg transition-all duration-300 border border-base-200"
>
    <div class="card-body items-center text-center p-6">
        <div class="avatar avatar-placeholder mb-2">
            <div class="bg-base-300 rounded-full w-16 print:w-12">
                <slot name="icon" />
            </div>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
            <SkillsList items={items} />
        </div>
    </div>
</div>
